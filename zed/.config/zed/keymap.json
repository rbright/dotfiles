// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  // Workspace
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-alt-p": "git::Worktree",
      // Project Picker
      "ctrl-alt-o": [
        "projects::OpenRecent",
        {
          "create_new_window": true
        }
      ],
      // Panels
      "ctrl-shift-g": "git_panel::ToggleFocus",
      "ctrl-shift-b": "outline_panel::ToggleFocus",
      "ctrl-`": "terminal_panel::Toggle"
    }
  },
  {
    "context": "os == linux > Workspace",
    "bindings": {
      "ctrl-k ctrl-w": "workspace::CloseAllItemsAndPanes",
      // File Finder
      "ctrl-p": "file_finder::Toggle",
      // Panels
      "ctrl-?": "agent::ToggleFocus",
      "ctrl-shift-e": "project_panel::ToggleFocus",
    }
  },
  {
    "context": "os == macos > Workspace",
    "bindings": {
      "cmd-k cmd-w": "workspace::CloseAllItemsAndPanes",
      "cmd-shift-w": "workspace::CloseWindow",
      // File Finder
      "cmd-p": "file_finder::Toggle",
      "ctrl-alt-super-o": [
        "projects::OpenRemote",
        {
          "create_new_window": false,
          "from_existing_connection": false
        }
      ],
      // Panels
      "cmd-?": "agent::ToggleFocus",
      "cmd-shift-e": "project_panel::ToggleFocus"
    }
  },
  // Pane
  {
    "context": "os == linux > Pane",
    "bindings": {
      "ctrl-alt-[": "pane::ActivatePreviousItem",
      "ctrl-alt-]": "pane::ActivateNextItem",
      "ctrl-w": [
        "pane::CloseActiveItem",
        {
          "close_pinned": false
        }
      ],
      "ctrl-k w": [
        "pane::CloseAllItems",
        {
          "close_pinned": false
        }
      ],
      "ctrl-alt-g": "search::SelectNextMatch"
    },
  },
  {
    "context": "os == macos > Pane",
    "bindings": {
      "cmd-shift-[": "pane::ActivatePreviousItem",
      "cmd-shift-]": "pane::ActivateNextItem",
      "cmd-w": [
        "pane::CloseActiveItem",
        {
          "close_pinned": false
        }
      ],
      "cmd-k w": [
        "pane::CloseAllItems",
        {
          "close_pinned": false
        }
      ],
    },
  },
  // Editor
  {
    "context": "Editor",
    "bindings": {
      "ctrl-shift-i": null,
      // Pane Navigation
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-j": "workspace::ActivatePaneDown",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-l": "workspace::ActivatePaneRight",
      // Pane Splitting
      "ctrl-shift-h": "pane::SplitLeft",
      "ctrl-shift-j": "pane::SplitDown",
      "ctrl-shift-k": "pane::SplitUp",
      "ctrl-shift-l": "pane::SplitRight"
    }
  },
  {
    "context": "Editor && mode == full",
    "bindings": {
      "ctrl-shift-o": "outline::Toggle",
      "ctrl-g": "go_to_line::Toggle",
    },
  },
  {
    "context": "os == linux > Editor",
    "bindings": {
      "ctrl-c": "editor::Copy",
      "ctrl-v": "editor::Paste",
      "ctrl-a": "editor::SelectAll",
    }
  },
  {
    "context": "os == macos > Editor",
    "bindings": {
      "cmd-a": "editor::SelectAll",
    }
  },
  // AgentPanel
  {
    "context": "AgentPanel",
    "bindings": {
      "alt-cmd-p": null
    }
  },
  // Git Panel
  {
    "context": "GitPanel && ChangesList",
    "bindings": {
      "ctrl-shift-g": "git::GenerateCommitMessage"
    }
  },
  {
    "context": "CommitEditor > Editor",
    "bindings": {
      "alt-tab": null,
      "ctrl-shift-g": "git::GenerateCommitMessage"
    }
  },
  {
    "context": "GitCommit > Editor",
    "bindings": {
      "alt-tab": null
    }
  },
  // Terminal
  {
    "context": "os == linux > Terminal",
    "bindings": {
      "ctrl-shift-c": "terminal::Copy",
      "ctrl-shift-v": "terminal::Paste"
    }
  },
  {
    "context": "ProjectPanel && not_editing",
    "unbind": {
      ":": "command_palette::Toggle"
    }
  }
]
